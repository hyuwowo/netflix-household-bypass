{
  "name": "Netflix Household Bypass",
  "description": "Stream Netflix content across networks seamlessly. Automatically manages household and location checks.",
  "version": "1.0.0",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "web_accessible_resources": [
    {
        "resources": [
          "interceptor.js"
        ],
        "matches": ["*://*.netflix.com/*"]
    }
  ],
  "content_scripts": [
    {
      "js": ["loader.js"],
      "matches": ["*://*.netflix.com/*"],
      "run_at": "document_start"
    },
    {
      "js": ["content.js"],
      "css": ["styles.css"],
      "matches": [
        "*://*.netflix.com/*"
      ]
    }
  ]
}
